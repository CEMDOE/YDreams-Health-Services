---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";

const services = [
  {
    title: "Cuidado General de Enfermeria",
    image: "/images/hero.jpg",
    summary: "Atencion integral para pacientes que requieren acompanamiento continuo o temporal en casa.",
    description:
      "Incluye evaluacion inicial, ejecucion del plan de cuidado y comunicacion frecuente con familiares y medico tratante.",
    bullets: ["Higiene y confort", "Control de medicacion indicada", "Prevencion de complicaciones", "Registro y seguimiento"],
  },
  {
    title: "Administracion de Medicamentos",
    image: "/images/hero.jpg",
    summary: "Aplicacion segura de medicacion segun prescripcion, con verificaciones en cada etapa.",
    description:
      "Gestionamos dosis y horarios, vigilamos posibles reacciones y documentamos cada intervencion para continuidad segura.",
    bullets: ["Checklist de seguridad", "Educacion al paciente", "Registro de dosis y horarios", "Alertas a familia y medico"],
  },
  {
    title: "Cuidado Postoperatorio",
    image: "/images/hero.jpg",
    summary: "Soporte profesional durante la recuperacion para disminuir riesgos y acelerar progreso.",
    description:
      "Monitoreamos signos de alerta, realizamos curaciones y orientamos sobre movilidad y autocuidado en casa.",
    bullets: ["Control de herida", "Manejo del dolor indicado", "Prevencion de infeccion", "Seguimiento diario"],
  },
  {
    title: "Fisioterapia a Domicilio",
    image: "/images/hero.jpg",
    summary: "Rehabilitacion funcional personalizada para recuperar autonomia con seguridad.",
    description:
      "Trabajamos rutinas graduales con objetivos medibles para fortalecer movilidad, marcha y estabilidad.",
    bullets: ["Rutina personalizada", "Progresion por objetivos", "Entrenamiento de marcha", "Prevencion de recaidas"],
  },
  {
    title: "Monitoreo de Signos Vitales",
    image: "/images/hero.jpg",
    summary: "Control periodico de indicadores clave para deteccion temprana y decisiones oportunas.",
    description:
      "Registramos tendencias de presion, frecuencia cardiaca, saturacion y otros parametros segun el caso.",
    bullets: ["Toma y registro", "Lectura de tendencias", "Comunicacion con familia", "Recomendaciones basicas"],
  },
  {
    title: "Educacion para Pacientes y Familiares",
    image: "/images/hero.jpg",
    summary: "Formacion practica para cuidar mejor al paciente entre visitas de seguimiento.",
    description:
      "Ensenamos rutinas, senales de alerta y medidas preventivas para fortalecer la autonomia del hogar.",
    bullets: ["Guias claras", "Demostracion y practica", "Plan de cuidados", "Espacio para dudas"],
  },
] as const;
---

<Layout
  title="Servicios | YDreams Health Services"
  description="Servicios de enfermeria a domicilio con enfoque clinico, comunicacion clara y acompanamiento humano."
>
  <section class="section-spacing">
    <div class="container-page">
      <div class="surface-card rounded-2xl p-8 sm:p-10">
        <h1 class="text-3xl font-semibold text-slate-900">Servicios de enfermeria para cada etapa del cuidado</h1>
        <p class="mt-3 max-w-3xl text-sm text-slate-600">
          Disenamos intervenciones domiciliarias claras, medibles y centradas en seguridad para que tu familia tome decisiones con confianza.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-page space-y-8">
      {services.map((s, index) => (
        <article
          class:list={[
            "grid gap-6 rounded-2xl border border-slate-200 p-6 shadow-soft md:grid-cols-5 md:items-center md:p-8",
            index % 2 === 0 ? "bg-white" : "bg-mint-50/70",
          ]}
        >
          <div class="md:col-span-2">
            <img
              src={s.image}
              alt={`Imagen representativa de ${s.title}`}
              class="h-52 w-full rounded-2xl object-cover ring-1 ring-slate-200 md:h-60"
              loading="lazy"
            />
          </div>

          <div class="md:col-span-3">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Servicio especializado</p>
            <h2 class="mt-2 text-xl font-semibold text-slate-900">{s.title}</h2>
            <p class="mt-3 text-sm font-medium text-slate-700">{s.summary}</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{s.description}</p>

            <ul class="mt-4 grid gap-2 text-sm text-slate-700 sm:grid-cols-2">
              {s.bullets.map((b) => (
                <li class="flex gap-2">
                  <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-md bg-mint-100 ring-1 ring-mint-200">
                    <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true" class="text-mint-700">
                      <path fill="currentColor" d="M9 16.2l-3.5-3.5L4 14.2 9 19l11-11-1.4-1.4z"/>
                    </svg>
                  </span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a href="/contact" class="inline-flex items-center justify-center rounded-xl bg-brand-600 px-5 py-3 text-sm font-semibold text-white hover:bg-brand-700">
                Solicitar este servicio
              </a>
              <a href="/contact" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50">
                Consultar disponibilidad
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTASection
    title="Necesitas orientacion para elegir el servicio adecuado?"
    subtitle="Cuentanos la situacion del paciente y te ayudamos a definir el plan de atencion inicial."
    ctaLabel="Hablar con el equipo"
    href="/contact"
    variant="subtle"
  />
</Layout>
