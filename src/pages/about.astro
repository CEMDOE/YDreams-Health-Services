---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";

const team = [
  {
    name: "Ana Torres",
    title: "Enfermera Jefe | Cuidados Domiciliarios",
    bio: "Coordina planes clinicos personalizados y seguimiento familiar basado en protocolos.",
    image: "/images/nurse-team.jpg",
  },
  {
    name: "Luis Ramirez",
    title: "Enfermero | Postoperatorio y Curaciones",
    bio: "Especialista en recuperacion postquirurgica, curaciones y deteccion temprana de alertas.",
    image: "/images/nurse-team.jpg",
  },
  {
    name: "Carla Vega",
    title: "Fisioterapeuta | Rehabilitacion Funcional",
    bio: "Disena rutinas de movilidad seguras para recuperar autonomia de forma progresiva.",
    image: "/images/nurse-team.jpg",
  },
] as const;

const pillars = [
  "Protocolos clinicos claros",
  "Comunicacion transparente",
  "Trato humano y cercano",
] as const;
---

<Layout
  title="Sobre Nosotros | YDreams Health Services"
  description="Conoce el enfoque de YDreams Health Services: seguridad clinica, empatia y acompanamiento domiciliario."
>
  <section class="section-spacing">
    <div class="container-page">
      <div class="surface-card rounded-2xl p-8 sm:p-10">
        <h1 class="text-3xl font-semibold text-slate-900">Un equipo de salud en casa, con metodo y confianza</h1>
        <p class="mt-3 max-w-3xl text-sm text-slate-600">
          En YDreams Health Services acompanamos procesos de cuidado domiciliario con estructura clinica, empatia y comunicacion constante con cada familia.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-page grid gap-8 lg:grid-cols-2 lg:items-center">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
        <h2 class="text-xl font-semibold text-slate-900">Mision y forma de trabajo</h2>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          Nuestra mision es ofrecer cuidados de enfermeria a domicilio que combinen seguridad, cercania y decisiones basadas en evaluacion continua.
        </p>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">
          Trabajamos con un flujo claro: valoracion inicial, plan de cuidado, seguimiento documentado y comunicacion con paciente y familiares.
        </p>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          {pillars.map((pillar) => (
            <div class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200">
              <p class="text-sm font-semibold text-slate-900">{pillar}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <img
          src="/images/nurse-team.jpg"
          alt="Equipo de enfermeria de YDreams Health Services"
          class="h-80 w-full rounded-2xl object-cover shadow-soft ring-1 ring-slate-200"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-page">
      <h2 class="text-2xl font-semibold text-slate-900">Equipo profesional</h2>
      <p class="mt-2 max-w-2xl text-sm text-slate-600">
        Profesionales con experiencia en cuidado domiciliario, recuperacion y educacion para pacientes y familiares.
      </p>

      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {team.map((member) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft">
            <img
              src={member.image}
              alt={`Foto de ${member.name}`}
              class="h-40 w-full rounded-2xl object-cover ring-1 ring-slate-200"
              loading="lazy"
            />
            <h3 class="mt-4 text-base font-semibold text-slate-900">{member.name}</h3>
            <p class="mt-1 text-xs font-medium uppercase tracking-wide text-brand-700">{member.title}</p>
            <p class="mt-3 text-sm text-slate-600">{member.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Agenda una valoracion inicial con nuestro equipo"
    subtitle="Te orientamos para definir el servicio adecuado y el plan de acompanamiento en casa."
    ctaLabel="Solicitar valoracion"
    href="/contact"
  />
</Layout>
