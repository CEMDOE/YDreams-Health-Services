---
import Layout from "../layouts/Layout.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import CTASection from "../components/CTASection.astro";

const testimonials = [
  {
    name: "Maria R.",
    role: "Familiar de paciente",
    quote: "La comunicacion fue clara desde la primera visita y siempre tuvimos seguimiento puntual.",
    image: "/images/patient-1.jpg",
    rating: 5,
  },
  {
    name: "Carlos P.",
    role: "Paciente",
    quote: "Recibi atencion profesional y respetuosa. El equipo me dio mucha tranquilidad.",
    image: "/images/patient-2.jpg",
    rating: 5,
  },
  {
    name: "Lucia G.",
    role: "Paciente",
    quote: "Explican cada paso del cuidado y eso hace una gran diferencia para la familia.",
    image: "/images/patient-3.jpg",
    rating: 5,
  },
  {
    name: "Jorge M.",
    role: "Familiar de paciente",
    quote: "Siempre puntuales, atentos y con un enfoque muy humano durante todo el proceso.",
    image: "/images/patient-1.jpg",
    rating: 5,
  },
  {
    name: "Elena S.",
    role: "Paciente postoperatoria",
    quote: "Me senti acompanada en casa con seguridad y orientacion profesional constante.",
    image: "/images/patient-2.jpg",
    rating: 5,
  },
] as const;
---

<Layout
  title="Testimonios | YDreams Health Services"
  description="Historias reales de pacientes y familias atendidos por YDreams Health Services en casa."
>
  <section class="section-spacing">
    <div class="container-page">
      <div class="surface-card rounded-2xl p-8 sm:p-10">
        <h1 class="text-3xl font-semibold text-slate-900">Historias de confianza en cuidado domiciliario</h1>
        <p class="mt-3 max-w-3xl text-sm text-slate-600">
          Pacientes y familiares comparten su experiencia con nuestro equipo, destacando seguridad, cercania y claridad en cada fase del cuidado.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-page grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((testimonial) => (
        <TestimonialCard {...testimonial} />
      ))}
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="surface-card rounded-2xl p-6 sm:p-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-slate-900">Quieres compartir tu experiencia?</h2>
          <p class="mt-1 text-sm text-slate-600">
            Puedes escribirnos desde contacto y nuestro equipo publicara tu testimonio con tu autorizacion.
          </p>
        </div>
        <a href="/contact" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50">
          Enviar testimonio
        </a>
      </div>
    </div>
  </section>

  <CTASection
    title="Buscas cuidado profesional para un familiar?"
    subtitle="Completa el formulario de contacto y te guiaremos con el siguiente paso de atencion."
    ctaLabel="Ir a contacto"
    href="/contact"
    variant="subtle"
  />
</Layout>
