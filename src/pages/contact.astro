---
import '../styles/globals.css';
import Layout from "../layouts/Layout.astro";

const serviceOptions = [
  "Cuidado General de Enfermería",
  "Administración de Medicamentos",
  "Cuidado Postoperatorio",
  "Fisioterapia a Domicilio",
  "Monitoreo de Signos Vitales",
  "Educación para Pacientes y Familiares",
];
---

<Layout title="Contacto | NurseCare" description="Contáctanos y agenda tu consulta.">
  <!-- HERO -->
  <section class="container-page py-14 sm:py-16">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-soft sm:p-10">
      <h1 class="text-3xl font-semibold text-slate-900">Contáctanos y Agenda tu Consulta</h1>
      <p class="mt-3 max-w-2xl text-sm text-slate-600">
        Completa el formulario y te responderemos a la brevedad.
      </p>
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="grid gap-8 lg:grid-cols-5">
      <!-- FORM -->
      <div class="lg:col-span-3">
        <form
          class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8"
          method="post"
          action="#"
        >
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="name" class="text-sm font-semibold text-slate-800">Nombre</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-brand-400"
                placeholder="Licda.Ylanda "
              />
            </div>

            <div>
              <label for="phone" class="text-sm font-semibold text-slate-800">Teléfono</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                required
                autocomplete="tel"
                class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-brand-400"
                placeholder="+829-843-6803"
              />
            </div>

            <div class="sm:col-span-2">
              <label for="email" class="text-sm font-semibold text-slate-800">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-brand-400"
                placeholder="ylandacaetam@gmail.com"
              />
            </div>

            <div class="sm:col-span-2">
              <label for="service" class="text-sm font-semibold text-slate-800">Tipo de Servicio de Interés</label>
              <select
                id="service"
                name="service"
                required
                class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-brand-400"
              >
                <option value="" disabled selected>Selecciona una opción</option>
                {serviceOptions.map((opt) => <option value={opt}>{opt}</option>)}
              </select>
            </div>

            <div class="sm:col-span-2">
              <label for="message" class="text-sm font-semibold text-slate-800">Mensaje</label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="mt-2 w-full resize-y rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-brand-400"
                placeholder="Cuéntanos brevemente tu necesidad..."
              ></textarea>
              <p class="mt-2 text-xs text-slate-500">
                No compartas información médica sensible aquí. Te orientamos y luego coordinamos por canales seguros.
              </p>
            </div>
          </div>

          <button
            type="submit"
            class="mt-6 inline-flex w-full items-center justify-center rounded-xl bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-soft hover:bg-brand-700 sm:w-auto"
          >
            Enviar Mensaje
          </button>
        </form>
      </div>

      <!-- INFO -->
      <aside class="lg:col-span-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-soft sm:p-8">
          <h2 class="text-xl font-semibold text-slate-900">Información de Contacto</h2>
          <ul class="mt-4 space-y-2 text-sm text-slate-600">
            <li><span class="font-semibold text-slate-800">Tel:</span> +829-843-6803</li>
            <li><span class="font-semibold text-slate-800">Email:</span> ylandacaetam@gmail.com </li>
            <li><span class="font-semibold text-slate-800">Horario:</span> 24/7 (según servicio)</li>
            <li><span class="font-semibold text-slate-800">Dirección:</span> (calle Caonabo #69 , sector Gazcue </li>
          </ul>

          <div class="mt-6 rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200">
            <p class="text-sm font-semibold text-slate-900">Mapa (placeholder)</p>
            <div class="mt-3 flex h-44 items-center justify-center rounded-2xl border border-dashed border-slate-300 bg-white">
              <p class="text-xs text-slate-500">Aquí irá el embed de Google Maps</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>
</Layout>