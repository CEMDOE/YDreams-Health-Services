---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import CTASection from "../components/CTASection.astro";

const services = [
  {
    title: "Administracion de Medicamentos",
    description: "Control de dosis, horarios y observacion clinica para reducir riesgos.",
    icon: "syringe",
    eyebrow: "Seguridad diaria",
  },
  {
    title: "Cuidado Postoperatorio",
    description: "Acompanamiento en recuperacion con seguimiento continuo y educacion familiar.",
    icon: "heart",
    eyebrow: "Recuperacion guiada",
  },
  {
    title: "Monitoreo de Signos Vitales",
    description: "Registro claro de indicadores para decisiones oportunas con tu equipo medico.",
    icon: "clock",
    eyebrow: "Control preventivo",
  },
  {
    title: "Cuidado General de Enfermeria",
    description: "Atencion integral en casa basada en evaluacion y plan de cuidados personalizado.",
    icon: "cross",
    eyebrow: "Atencion continua",
  },
] as const;

const testimonials = [
  {
    name: "Maria R.",
    role: "Familiar de paciente",
    quote: "Nos explicaron cada paso con calma y sentimos confianza desde el primer dia.",
    image: "/images/patient-1.jpg",
    rating: 5,
  },
  {
    name: "Carlos P.",
    role: "Paciente",
    quote: "Puntualidad, trato humano y seguimiento real durante todo mi postoperatorio.",
    image: "/images/patient-2.jpg",
    rating: 5,
  },
  {
    name: "Lucia G.",
    role: "Paciente",
    quote: "El equipo transmite profesionalismo y claridad. Muy recomendado para cuidado en casa.",
    image: "/images/patient-3.jpg",
    rating: 5,
  },
] as const;
---

<Layout
  title="YDreams Health Services | Enfermeria a Domicilio"
  description="Cuidado de enfermeria profesional en casa con protocolos clinicos, empatia y respuesta oportuna."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero.jpg"
        alt="Enfermera atendiendo a un paciente en casa"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-brand-900/65"></div>
    </div>

    <div class="container-page relative py-24 sm:py-28">
      <div class="max-w-2xl text-white">
        <p class="text-sm font-semibold uppercase tracking-wider text-white/80">YDreams Health Services</p>
        <h1 class="mt-3 text-3xl font-semibold leading-tight sm:text-5xl">
          Cuidado de enfermeria profesional en la comodidad de tu hogar
        </h1>
        <p class="mt-5 text-lg text-white/90">
          Acompanamos a pacientes y familias con atencion clinica segura, trato humano y respuesta en menos de 24 horas.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-xl bg-white px-8 py-4 text-base font-semibold text-slate-900 transition hover:bg-slate-100"
          >
            Solicitar consulta
          </a>
          <a
            href="/services"
            class="inline-flex items-center justify-center rounded-xl border border-white/40 bg-white/10 px-8 py-4 text-base font-semibold text-white backdrop-blur transition hover:bg-white/20"
          >
            Ver servicios
          </a>
        </div>

        <div class="mt-6 flex flex-wrap gap-6 text-sm text-white/85">
          <span>Profesionales certificados</span>
          <span>Atencion domiciliaria</span>
          <span>Disponibilidad 24/7</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-page">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-2xl font-semibold text-brand-800">Servicios clave para cuidado en casa</h2>
          <p class="mt-2 text-sm text-slate-600">Intervenciones frecuentes para estabilidad, recuperacion y tranquilidad familiar.</p>
        </div>
        <a href="/services" class="text-sm font-semibold text-brand-700 hover:text-brand-800">Ver portafolio completo</a>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => (
          <ServiceCard title={s.title} description={s.description} icon={s.icon} eyebrow={s.eyebrow} />
        ))}
      </div>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-page">
      <div class="mb-8">
        <h2 class="text-2xl font-semibold text-brand-800">Lo que dicen nuestros pacientes</h2>
        <p class="mt-2 text-sm text-slate-600">Experiencias reales sobre acompanamiento, seguridad y calidad humana.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {testimonials.map((t) => (
          <TestimonialCard {...t} />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Coordina hoy la atencion de enfermeria que tu familia necesita"
    subtitle="Completa el formulario y te contactaremos para orientar el servicio ideal segun tu caso."
    ctaLabel="Ir a contacto"
    href="/contact"
  />
</Layout>
