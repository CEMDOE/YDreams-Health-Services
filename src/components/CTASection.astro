---
type Variant = "primary" | "subtle";

interface Props {
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  href?: string;
  variant?: Variant;
}

const {
  title = "Necesitas apoyo de enfermeria en casa?",
  subtitle = "Comparte tu caso y coordinamos la mejor opcion para tu familia.",
  ctaLabel = "Ir a contacto",
  href = "/contact",
  variant = "primary",
} = Astro.props as Props;

const isSubtle = variant === "subtle";
---

<section class="container-page pb-16">
  <div
    class:list={[
      "rounded-2xl p-8 sm:p-10",
      isSubtle
        ? "surface-card bg-white"
        : "bg-gradient-to-r from-brand-700 to-mint-700 shadow-soft",
    ]}
  >
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="max-w-2xl">
        <h2 class:list={["text-xl font-semibold sm:text-2xl", isSubtle ? "text-slate-900" : "text-white"]}>{title}</h2>
        <p class:list={["mt-2 text-sm", isSubtle ? "text-slate-600" : "text-white/90"]}>{subtitle}</p>
      </div>
      <a
        href={href}
        class:list={[
          "inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold transition",
          isSubtle
            ? "bg-brand-600 text-white hover:bg-brand-700"
            : "bg-white text-slate-900 hover:bg-slate-100",
        ]}
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</section>
