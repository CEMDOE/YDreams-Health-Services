---
type IconName = "cross" | "syringe" | "heart" | "clock";

interface Props {
  title: string;
  description: string;
  href?: string;
  icon?: IconName;
}

const {
  title,
  description,
  href = "/services",
  icon = "cross",
} = Astro.props as Props;

const icons: Record<IconName, string> = {
  cross: `<path fill="currentColor" d="M11 2h2v9h9v2h-9v9h-2v-9H2v-2h9z"/>`,
  syringe: `<path fill="currentColor" d="M20.7 7.3l-4-4-1.4 1.4 1.3 1.3-2.6 2.6-1.3-1.3-1.4 1.4 4 4 1.4-1.4-1.3-1.3 2.6-2.6 1.3 1.3zM3 21l6-6 2 2-6 6H3v-2z"/>`,
  heart: `<path fill="currentColor" d="M12 21s-7-4.4-9.5-8.7C.7 9.1 2.6 6 6 6c1.7 0 3 .9 4 2c1-1.1 2.3-2 4-2c3.4 0 5.3 3.1 3.5 6.3C19 16.6 12 21 12 21z"/>`,
  clock: `<path fill="currentColor" d="M12 2a10 10 0 1 0 0 20a10 10 0 0 0 0-20zm1 11h4v-2h-3V7h-2v6z"/>`,
};
---
---

<article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-soft transition hover:-translate-y-0.5">
  <div class="flex items-start gap-4">
    <div class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-50 ring-1 ring-brand-100">
      <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" class="text-brand-700">
        <Fragment set:html={icons[icon] ?? icons.cross} />
      </svg>
    </div>

    <div class="min-w-0">
      <h3 class="text-base font-semibold text-slate-900">{title}</h3>
      <p class="mt-2 text-sm text-slate-600">{description}</p>

      <a
        href={href}
        class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-800"
        aria-label={`Saber más sobre ${title}`}
      >
        Saber más
        <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M13 5l7 7-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6z"/>
        </svg>
      </a>
    </div>
  </div>
</article>