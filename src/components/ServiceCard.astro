---
type IconName = "cross" | "syringe" | "heart" | "clock";

interface Props {
  title: string;
  description: string;
  href?: string;
  icon?: IconName;
  eyebrow?: string;
}

const {
  title,
  description,
  href = "/services",
  icon = "cross",
  eyebrow,
} = Astro.props as Props;

const icons: Record<IconName, string> = {
  cross: `<path fill="currentColor" d="M11 2h2v9h9v2h-9v9h-2v-9H2v-2h9z"/>`,
  syringe: `<path fill="currentColor" d="M20.7 7.3l-4-4-1.4 1.4 1.3 1.3-2.6 2.6-1.3-1.3-1.4 1.4 4 4 1.4-1.4-1.3-1.3 2.6-2.6 1.3 1.3zM3 21l6-6 2 2-6 6H3v-2z"/>`,
  heart: `<path fill="currentColor" d="M12 21s-7-4.4-9.5-8.7C.7 9.1 2.6 6 6 6c1.7 0 3 .9 4 2c1-1.1 2.3-2 4-2c3.4 0 5.3 3.1 3.5 6.3C19 16.6 12 21 12 21z"/>`,
  clock: `<path fill="currentColor" d="M12 2a10 10 0 1 0 0 20a10 10 0 0 0 0-20zm1 11h4v-2h-3V7h-2v6z"/>`,
};
---

<a
  href={href}
  aria-label={`Saber mas sobre ${title}`}
  class="group flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-soft transition-all duration-300 hover:-translate-y-1 hover:border-brand-200 hover:shadow-xl"
>
  <div class="flex items-start gap-4">
    <div class="inline-flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-brand-50 ring-1 ring-brand-100 transition group-hover:bg-brand-100">
      <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" class="text-brand-700">
        <Fragment set:html={icons[icon]} />
      </svg>
    </div>

    <div class="min-w-0 flex-1">
      {eyebrow && <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{eyebrow}</p>}
      <h3 class="mt-1 text-base font-semibold text-slate-900 group-hover:text-brand-700">{title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>
    </div>
  </div>

  <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 transition group-hover:gap-3">
    Saber mas
    <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" class="transition group-hover:translate-x-1">
      <path fill="currentColor" d="M13 5l7 7-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6z" />
    </svg>
  </div>
</a>
