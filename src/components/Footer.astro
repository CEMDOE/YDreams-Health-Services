---
const nav = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/services" },
  { label: "Sobre Nosotros", href: "/about" },
  { label: "Testimonios", href: "/testimonials" },
  { label: "Contacto", href: "/contact" },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white">
  <div class="container-page py-12">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <div class="flex items-center gap-2 font-semibold text-slate-900">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-brand-50 ring-1 ring-brand-100">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" class="text-brand-600">
              <path fill="currentColor" d="M11 2h2v9h9v2h-9v9h-2v-9H2v-2h9z"/>
            </svg>
          </span>
          <span>NurseCare</span>
        </div>
        <p class="mt-3 max-w-sm text-sm text-slate-600">
          Atención de enfermería a domicilio con profesionalismo, calidez y seguridad.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900">Navegación</h3>
        <ul class="mt-3 space-y-2">
          {nav.map((item) => (
            <li>
              <a class="text-sm text-slate-600 hover:text-slate-900" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-slate-900">Contacto</h3>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li><span class="font-medium text-slate-800">Tel:</span> +51 999 999 999</li>
          <li><span class="font-medium text-slate-800">Email:</span> contacto@nursecare.com</li>
          <li><span class="font-medium text-slate-800">Dirección:</span> (Opcional) Av. Ejemplo 123, Ciudad</li>
        </ul>

        <div class="mt-4 flex gap-3" aria-label="Redes sociales">
          <!-- Icons placeholder -->
          <a href="#" class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 hover:bg-slate-50" aria-label="Twitter/X">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" class="text-slate-700">
              <path fill="currentColor" d="M18.9 2H22l-6.8 7.8L23 22h-6.8l-5.3-6.9L4.8 22H2l7.3-8.4L1 2h7l4.8 6.3L18.9 2z"/>
            </svg>
          </a>
          <a href="#" class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 hover:bg-slate-50" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" class="text-slate-700">
              <path fill="currentColor" d="M13 22v-8h3l1-4h-4V7c0-1.1.4-2 2-2h2V1h-3c-3.3 0-5 2-5 5v4H8v4h3v8h2z"/>
            </svg>
          </a>
          <a href="#" class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 hover:bg-slate-50" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" class="text-slate-700">
              <path fill="currentColor" d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm10 2H7a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3zm-5 4a5 5 0 1 1 0 10a5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6a3 3 0 0 0 0-6zm5.5-.9a1.1 1.1 0 1 1 0 2.2a1.1 1.1 0 0 1 0-2.2z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-slate-200 pt-6 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} NurseCare. Todos los derechos reservados.</p>
      <p>Hecho con cuidado y privacidad en mente.</p>
    </div>
  </div>
</footer>